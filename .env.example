# Polygon Amoy Testnet RPC URL (Optional - defaults are provided)
AMOY_RPC_URL=https://rpc-amoy.polygon.technology

# Ethereum Sepolia Testnet RPC URL
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY

# Private Key for deployment wallet
# IMPORTANT: NEVER commit .env file with real private keys to git
# This should only contain a testnet wallet private key (without 0x prefix)
PRIVATE_KEY=your_testnet_wallet_private_key_here

# IPFS / Pinata Credentials (Assignment 4)
PINATA_JWT=your_pinata_jwt_token_here
